    "eip712",
    "defi",
    "rwa"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rpnny/ilal",
    "directory": "sdk"
  },
  "homepage": "https://github.com/rpnny/ilal/tree/main/sdk#readme",
  "publishConfig": {
