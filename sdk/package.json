{
  "name": "@ilalv3/sdk",
  "version": "0.2.0",
  "description": "ILAL Protocol SDK — session signing and hookData encoding for Uniswap v4 compliance pools",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "Apache-2.0",
  "keywords": [
    "uniswap",
    "uniswap-v4",
