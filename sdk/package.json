  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc",
    "test": "vitest run src"
  },
  "dependencies": {
    "viem": "^2.52.2"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
