{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ilal.tech/schemas/deployment-manifest-v1.json",
  "title": "ILAL deployment manifest",
  "type": "object",
  "required": ["schemaVersion", "version", "status", "network", "chainId", "contracts", "features", "releaseStatus"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "version": { "type": "string" },
    "status": { "enum": ["candidate", "active", "deprecated"] },
    "network": { "type": "string" },
    "chainId": { "type": "integer", "minimum": 1 },
    "sourceCommit": { "anyOf": [{ "type": "string", "pattern": "^[0-9a-f]{40}$" }, { "type": "null" }] },
    "releaseCommit": { "anyOf": [{ "type": "string", "pattern": "^[0-9a-f]{40}$" }, { "type": "null" }] },
    "deployer": { "anyOf": [{ "$ref": "#/$defs/address" }, { "type": "null" }] },
    "admin": { "$ref": "#/$defs/address" },
    "treasury": { "$ref": "#/$defs/address" },
    "adminTreasuryShared": { "type": "boolean" },
    "contracts": { "type": "object", "minProperties": 1, "additionalProperties": { "anyOf": [{ "$ref": "#/$defs/address" }, { "$ref": "#/$defs/contract" }] } },
    "pool": { "type": "object" },
    "toolchain": {
      "type": "object",
      "required": ["solc", "optimizerEnabled", "optimizerRuns", "viaIR", "evmVersion", "remappings", "libraries"],
      "properties": {
        "solc": { "type": "string" },
        "optimizerEnabled": { "type": "boolean" },
        "optimizerRuns": { "type": "integer" },
        "viaIR": { "type": "boolean" },
        "evmVersion": { "type": "string" },
        "remappings": { "type": "array", "items": { "type": "string" } },
        "libraries": { "type": "object" }
      },
      "additionalProperties": false
    },
    "sourceTreeHash": { "$ref": "#/$defs/hash" },
    "privilegedRoles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["capability", "applicable", "contract", "holder", "verificationCall", "result", "deployerRetained"],
        "properties": {
          "capability": { "type": "string" },
          "applicable": { "type": "boolean" },
          "contract": { "anyOf": [{ "$ref": "#/$defs/address" }, { "type": "null" }] },
          "holder": { "anyOf": [{ "$ref": "#/$defs/address" }, { "type": "null" }] },
          "verificationCall": { "type": "string" },
          "result": { "type": "string" },
          "deployerRetained": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "features": { "type": "object" },
    "releaseStatus": {
      "type": "object",
      "required": ["software", "deployment"],
      "properties": {
        "software": { "type": "string" },
        "deployment": { "type": "string" }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "enum": ["candidate", "active"] } } },
      "then": {
        "required": ["sourceCommit", "releaseCommit", "deployer", "admin", "treasury", "adminTreasuryShared", "pool", "toolchain", "sourceTreeHash", "privilegedRoles"],
        "properties": {
          "pool": {
            "required": ["poolId", "initializationTransactionHash", "initializationBlockNumber", "key"],
            "properties": {
              "poolId": { "$ref": "#/$defs/hash" },
              "initializationTransactionHash": { "$ref": "#/$defs/hash" },
              "initializationBlockNumber": { "type": "integer", "minimum": 1 },
              "key": {
                "type": "object",
                "required": ["currency0", "currency1", "fee", "tickSpacing", "hook"],
                "properties": {
                  "currency0": { "$ref": "#/$defs/address" },
                  "currency1": { "$ref": "#/$defs/address" },
                  "fee": { "type": "integer", "minimum": 0, "maximum": 16777215 },
                  "tickSpacing": { "type": "integer" },
                  "hook": { "$ref": "#/$defs/address" }
                },
                "additionalProperties": false
              }
            }
          },
          "features": {
            "required": ["attestation", "zk", "audit", "productionReadiness"],
            "properties": {
              "attestation": { "type": "string" },
              "zk": { "type": "string" },
              "audit": { "type": "string" },
              "productionReadiness": { "type": "string" }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "address": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
    "hash": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "contract": {
      "type": "object",
      "required": ["address", "transactionHash", "blockNumber", "constructorArguments", "creationBytecodeHash", "runtimeBytecodeHash", "abiHash", "create2Salt"],
      "properties": {
        "address": { "$ref": "#/$defs/address" },
        "transactionHash": { "$ref": "#/$defs/hash" },
        "blockNumber": { "type": "integer" },
        "constructorArguments": { "type": "string" },
        "creationBytecodeHash": { "$ref": "#/$defs/hash" },
        "runtimeBytecodeHash": { "$ref": "#/$defs/hash" },
        "abiHash": { "$ref": "#/$defs/hash" },
        "create2Salt": { "anyOf": [{ "$ref": "#/$defs/hash" }, { "type": "null" }] }
      }
    }
  }
}
