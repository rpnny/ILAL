    "poseidon-lite": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "circomlibjs": "^0.1.7",
    "snarkjs": "^0.7.6",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
