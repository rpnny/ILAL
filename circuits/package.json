{
  "name": "@ilal/circuits",
  "version": "0.1.0",
  "description": "ILAL Protocol Circom circuits — ZK eligibility proof",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/rpnny/ilal",
    "directory": "circuits"
  },
  "scripts": {
    "compile": "bash scripts/compile.sh",
