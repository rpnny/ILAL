{
  "name": "@ilalv3/cli",
  "version": "0.3.3",
  "description": "ILAL Protocol CLI — compliant swaps and credential management for Uniswap v4",
  "type": "module",
  "bin": {
    "ilal": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "Apache-2.0",
  "keywords": [
    "uniswap",
    "uniswap-v4",
    "compliance",
    "kyc",
    "zk-proof",
    "defi",
    "rwa",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rpnny/ilal.git",
    "directory": "cli"
  },
  "homepage": "https://github.com/rpnny/ilal/tree/main/cli#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --loader ts-node/esm src/index.ts",
    "start": "node dist/index.js",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "@zk-kit/incremental-merkle-tree": "^1.1.0",
    "commander": "^12.0.0",
    "poseidon-lite": "^0.3.0",
    "snarkjs": "^0.7.6",
    "viem": "^2.52.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  },
  "overrides": {
    "underscore": "1.13.8",
    "ws": "^8.21.0"
  }
}
