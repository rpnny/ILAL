{
  "name": "@ilalv3/cli",
  "version": "0.1.2",
  "description": "ILAL Protocol CLI — compliant swaps and credential management for Uniswap v4",
  "type": "module",
  "bin": {
    "ilal": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "MIT",
  "keywords": [
    "uniswap",
    "uniswap-v4",
    "compliance",
    "kyc",
    "zk-proof",
    "defi",
    "rwa",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ilal-protocol/ilal.git"
  },
  "homepage": "https://github.com/ilal-protocol/ilal#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
