    "start": "node dist/index.js"
  },
  "dependencies": {
    "@zk-kit/incremental-merkle-tree": "^1.1.0",
    "commander": "^12.0.0",
    "poseidon-lite": "^0.3.0",
    "viem": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
